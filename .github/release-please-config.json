{
  "release-type": "python",
  "packages": {
    ".": {
      "release-type": "python",
      "changelog-path": "CHANGELOG.md",
      "extra-files": [
        "app/__init__.py",
        {
          "type": "toml",
          "path": "uv.lock",
          "jsonpath": "$.package[?(@.name=='codex-lb')].version"
        },
        {
          "type": "json",
          "path": "frontend/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "yaml",
          "path": "deploy/helm/codex-lb/Chart.yaml",
          "jsonpath": "$.version"
        },
        {
          "type": "yaml",
          "path": "deploy/helm/codex-lb/Chart.yaml",
          "jsonpath": "$.appVersion"
        }
      ]
    }
  }
}
